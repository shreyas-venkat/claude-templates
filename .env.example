# GitHub
# Create at: https://github.com/settings/tokens
# Scopes needed: repo, read:org, read:user
GITHUB_TOKEN=

# Google / Gmail
# Gmail uses file-based OAuth — no env vars needed here.
# One-time setup: npx @gongrzhe/server-gmail-autoauth-mcp auth
# This opens a browser, you sign in, and credentials are saved to ~/.gmail-mcp/

# MotherDuck
# Get at: https://app.motherduck.com/account/settings
MOTHERDUCK_TOKEN=

# VPS (coming soon)
# VPS_HOST=
# VPS_USER=
# VPS_SSH_KEY_PATH=
